/* pages/profile/profile.wxss */

.header {
  background: linear-gradient(135deg, #1E3A5F 0%, #2B7DE9 100%);
  padding: 48rpx 32rpx 40rpx;
  display: flex; flex-direction: column; align-items: center;
}
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.35); margin-bottom: 16rpx; }
.name { font-size: 36rpx; font-weight: 700; color: #FFFFFF; }
.role { font-size: 24rpx; color: rgba(255,255,255,0.7); margin-top: 6rpx; }

.stats-bar {
  display: flex; background: #FFFFFF;
  margin: -20rpx 24rpx 20rpx; border-radius: 18rpx;
  padding: 24rpx 0; box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  position: relative; z-index: 10;
}
.stat { flex: 1; text-align: center; }
.stat-num { font-size: 38rpx; font-weight: 700; color: #1A1A1A; display: block; }
.stat-lbl { font-size: 22rpx; color: #8C9BAB; margin-top: 4rpx; display: block; }
.stat-divider { width: 1rpx; background: #E5E7EB; }

.menu-group { margin: 0 24rpx 16rpx; background: #FFFFFF; border-radius: 14rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03); }
.menu-row { display: flex; align-items: center; padding: 26rpx 24rpx; }
.menu-row + .menu-row { border-top: 1rpx solid #F3F4F6; }
.m-icon { font-size: 32rpx; margin-right: 16rpx; }
.m-label { font-size: 28rpx; color: #1A1A1A; flex: 1; }
.m-arrow { font-size: 36rpx; color: #D1D5DB; }

.footer { text-align: center; padding: 36rpx 0 48rpx; font-size: 20rpx; color: #C9CDD4; }