/* pages/index/index.wxss */

/* ===== 一体化顶部区域（品牌+搜索）深蓝通顶 ===== */
.header-area {
  background: linear-gradient(135deg, #1E3A5F 0%, #2B7DE9 100%);
  padding: 36rpx 28rpx 32rpx;
  padding-top: calc(36rpx + env(safe-area-inset-top));
}

/* 品牌Logo - Apple风格：圆润现代 */
.header-brand-row {
  margin-bottom: 24rpx;
}

.brand-logo {
  font-size: 52rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 8rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', Arial, sans-serif;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.18);
  border-radius: 36rpx;
  padding: 18rpx 28rpx;
  gap: 14rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.8;
}

.search-placeholder {
  font-size: 27rpx;
  color: rgba(255,255,255,0.6);
}

/* ===== 轮播Banner ===== */
.banner-swiper {
  height: 300rpx;
  margin: 0 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  z-index: 10;
  margin-top: -8rpx;
}

.banner-item {
  height: 100%;
  background: linear-gradient(135deg, #1E3A5F 0%, #2B7DE9 60%, #5B9BF0 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: flex-end;
  padding: 40rpx 36rpx;
}

.banner-inner {
  display: flex;
  flex-direction: column;
}

.banner-tag {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.15);
  padding: 6rpx 18rpx;
  border-radius: 6rpx;
  align-self: flex-start;
  margin-bottom: 16rpx;
}

.banner-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.4;
  max-width: 500rpx;
}

.banner-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 12rpx;
}

/* ===== 分类导航 ===== */
.category-section {
  padding: 32rpx 24rpx 12rpx;
}

.category-scroll { white-space: nowrap; }
.category-list { display: inline-flex; gap: 24rpx; }

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
}

.category-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.category-icon-img {
  width: 56rpx;
  height: 56rpx;
}

.category-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #374151;
}

/* ===== 区块通用 ===== */
.section-block { padding: 28rpx 0 8rpx; }

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx 20rpx;
}
.section-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.section-more { font-size: 24rpx; color: #8C9BAB; }

/* ===== 公告横滑卡片 ===== */
.announce-scroll { white-space: nowrap; padding: 0 28rpx; }

.announce-card {
  display: inline-flex;
  flex-direction: column;
  width: 520rpx;
  margin-right: 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
  vertical-align: top;
}

.announce-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.announce-tag {
  font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 6rpx; font-weight: 600;
}
.announce-tag.primary { background: #EFF6FF; color: #2B7DE9; }
.announce-tag.warning { background: #FFFBEB; color: #D97706; }
.announce-tag.default { background: #F3F4F6; color: #6B7280; }
.announce-date { font-size: 20rpx; color: #9CA3AF; }

.announce-title {
  font-size: 28rpx; font-weight: 600; color: #1A1A1A; line-height: 1.5;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  margin-bottom: 16rpx;
}

.announce-action { text-align: right; }
.announce-btn {
  font-size: 24rpx; color: #2B7DE9; font-weight: 500;
  padding: 8rpx 24rpx; background: #EFF6FF; border-radius: 20rpx; display: inline-block;
}

/* ===== 直播回放网格 ===== */
.live-grid { display: flex; flex-wrap: wrap; padding: 0 24rpx; gap: 16rpx; }

.live-card {
  width: calc(50% - 8rpx); background: #FFFFFF;
  border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.live-cover {
  width: 100%; height: 200rpx;
  background: linear-gradient(135deg, #1E3A5F, #374151);
  position: relative; display: flex; align-items: center; justify-content: center;
}

.play-overlay {
  width: 72rpx; height: 72rpx;
  background: rgba(43,125,233,0.9); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.play-circle { font-size: 26rpx; color: #FFFFFF; padding-left: 6rpx; }

.live-duration {
  position: absolute; bottom: 12rpx; right: 12rpx;
  font-size: 20rpx; color: #FFFFFF;
  background: rgba(0,0,0,0.55); padding: 4rpx 12rpx; border-radius: 6rpx;
}

.live-info { padding: 18rpx 20rpx; }
.live-title {
  font-size: 26rpx; font-weight: 600; color: #1A1A1A; line-height: 1.4;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.live-speaker { font-size: 22rpx; color: #8C9BAB; margin-top: 8rpx; display: block; }

.footer-space { height: 48rpx; }