/* pages/picloud/picloud.wxss */

.header {
  background: linear-gradient(135deg, #1E3A5F 0%, #2B7DE9 60%, #5B9BF0 100%);
  padding: 56rpx 32rpx 48rpx; text-align: center;
}
.header-title { font-size: 44rpx; font-weight: 700; color: #FFFFFF; letter-spacing: 4rpx; }
.header-sub { font-size: 24rpx; color: rgba(255,255,255,0.75); margin-top: 8rpx; }

.feature-grid {
  display: flex; flex-wrap: wrap; padding: 24rpx 16rpx;
  margin: -24rpx 24rpx 0; background: #FFFFFF;
  border-radius: 20rpx; box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  position: relative; z-index: 10;
}
.feature-card { width: 50%; display: flex; flex-direction: column; align-items: center; padding: 30rpx 12rpx; }
.feature-icon-wrap { width: 80rpx; height: 80rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 12rpx; }
.feature-icon { font-size: 36rpx; }
.feature-title { font-size: 28rpx; font-weight: 600; color: #1A1A1A; }
.feature-desc { font-size: 20rpx; color: #8C9BAB; margin-top: 6rpx; }

.section-header { padding: 36rpx 28rpx 20rpx; }
.section-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }

.doc-list { padding: 0 24rpx; }
.doc-item {
  display: flex; align-items: center; background: #FFFFFF;
  border-radius: 14rpx; padding: 22rpx 24rpx; margin-bottom: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.doc-icon { font-size: 34rpx; margin-right: 18rpx; }
.doc-body { flex: 1; }
.doc-name { font-size: 28rpx; font-weight: 500; color: #1A1A1A; display: block; }
.doc-time { font-size: 22rpx; color: #9CA3AF; margin-top: 6rpx; display: block; }
.doc-arrow { font-size: 36rpx; color: #D1D5DB; }

.footer-note { text-align: center; padding: 52rpx 0 40rpx; }
.footer-text { font-size: 24rpx; color: #8C9BAB; display: block; }
.footer-ver { font-size: 20rpx; color: #C9CDD4; margin-top: 6rpx; display: block; }